# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
# EXCEPTION: production build (dist/) may contain node_modules subdirs
# with font/asset files that MUST be included in deploy.
!dist/**/node_modules/
!dist/**/node_modules/**

# Expo
.expo/
# dist/  ← must NOT be ignored so production deploy includes frontend build
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

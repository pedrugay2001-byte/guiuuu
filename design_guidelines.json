{
  "app_name": "FarmaClube",
  "platform": "React Native (Expo)",
  "theme": "Dark",
  "archetype": "Archetype 5 (Jewel & Luxury) + Archetype 2 (Performance Pro)",
  "design_philosophy": "A premium, members-only fitness club experience. The visual language is predominantly black with silver, gray, and stark white accents. High contrast, sharp typography, and atmospheric photography are used to convey exclusivity and elite performance. No flashy colors; trust is built through minimalism and metallic tones.",
  "colors": {
    "background_base": "#050505",
    "surface_card": "#121212",
    "surface_elevated": "#1A1A1A",
    "primary": "#FFFFFF",
    "primary_text": "#F5F5F5",
    "secondary_text": "#A3A3A3",
    "border": "#262626",
    "accent_metallic": "#C0C0C0",
    "success_whatsapp": "#1EBE5D",
    "error": "#FF3B30",
    "overlay": "rgba(0, 0, 0, 0.7)"
  },
  "typography": {

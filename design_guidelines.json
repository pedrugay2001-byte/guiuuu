        "lineHeight": 24
      },
      "body_regular": {
        "fontSize": 14,
        "fontWeight": "400",
        "color": "#A3A3A3",
        "lineHeight": 20
      },
      "label": {
        "fontSize": 12,
        "fontWeight": "600",
        "textTransform": "uppercase",
        "letterSpacing": 1.5,
        "color": "#C0C0C0"
      }
    }
  },
  "spacing": {
